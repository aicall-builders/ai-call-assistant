APP_NAME="AI Call Assistant"
DEBUG=false

DATABASE_URL=sqlite:///./call_assistant.db

STT_PROVIDER=whisper
STT_MODEL=base

AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

KEYWORD_CONFIDENCE_THRESHOLD=0.7
AI_FALLBACK_THRESHOLD=0.4

# Calendar OAuth integration
# Redirect URI examples:
# - http://localhost:3000/oauth/google
# - http://localhost:3000/oauth/kakao
# - http://localhost:3000/oauth/naver
# - https://dk1k75g0ji3vw.cloudfront.net/oauth/google
# - https://dk1k75g0ji3vw.cloudfront.net/oauth/kakao
# - https://dk1k75g0ji3vw.cloudfront.net/oauth/naver
CORS_ALLOWED_ORIGINS=https://dk1k75g0ji3vw.cloudfront.net,http://localhost:3000
CALENDAR_TIMEZONE=Asia/Seoul
CALENDAR_DEFAULT_DURATION_MINUTES=60
CALENDAR_AUTO_MIGRATE=true
# Recommended in production. Without this, tokens are only Base64-encoded, not encrypted.
CALENDAR_TOKEN_KMS_KEY_ID=

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_SCOPE=https://www.googleapis.com/auth/calendar.events
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_CALENDAR_SCOPE=talk_calendar
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALENDAR_SCOPE=calendar
